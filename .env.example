LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_SKILL_GAP_LIMIT=3
LLM_GLOBAL_SKILL_ADVICE=1

# Required before public deployment. Use a long random string.
AUTH_SECRET=
AUTH_TOKEN_TTL_SECONDS=604800
CORS_ORIGINS=http://localhost:5173

# Optional cloud Postgres. Leave empty for local SQLite.
# Supabase example:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.bshplcsjqfjhgqyiscuk.supabase.co:5432/postgres
DATABASE_URL=
CAREER_AGENT_DB_URL=

# Abuse controls. Keep these conservative while using free API tiers.
MAX_TARGET_JOBS_PER_RUN=30
MAX_CUSTOM_QUERIES=6
RATE_LIMIT_API_PER_MINUTE=180
RATE_LIMIT_SIGNUP_PER_HOUR=6
RATE_LIMIT_LOGIN_PER_MINUTE=8
RATE_LIMIT_RUNS_PER_HOUR=5
RATE_LIMIT_TAILOR_PER_HOUR=12
RATE_LIMIT_PARSE_PER_HOUR=10
RATE_LIMIT_UPLOAD_PER_HOUR=12
RATE_LIMIT_KEYS_PER_HOUR=20

# Optional Adzuna API. Country code can be us, gb, ca, au, in, etc.
# Free signup at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional RapidAPI JSearch (Indeed/Google Jobs/LinkedIn aggregator).
# Free signup at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=
JSEARCH_API_KEY=

# Local-only LinkedIn prototype. Do not use for a deployed product.
LINKEDIN_COOKIE=
LINKEDIN_STORAGE_STATE=data/linkedin_state.json
LINKEDIN_PROFILE_DIR=data/linkedin_browser_profile

# SQLite database path used for the pipeline mirror
CAREER_AGENT_DB=data/career_agent.db
