LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_SKILL_GAP_LIMIT=3
LLM_GLOBAL_SKILL_ADVICE=1

# Optional Adzuna API. Country code can be us, gb, ca, au, in, etc.
# Free signup at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional RapidAPI JSearch (Indeed/Google Jobs/LinkedIn aggregator).
# Free signup at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=
JSEARCH_API_KEY=

# Local-only LinkedIn prototype. Do not use for a deployed product.
LINKEDIN_COOKIE=
LINKEDIN_STORAGE_STATE=data/linkedin_state.json
LINKEDIN_PROFILE_DIR=data/linkedin_browser_profile

# SQLite database path used for the pipeline mirror
CAREER_AGENT_DB=data/career_agent.db
